public class Musica {
    String titulo;
    String artista;
    int duracaoSegundos;
    String genero;

    public Musica(String titulo, String artista, int duracaoSegundos, String genero) {
        this.titulo = titulo;
        this.artista = artista;
        this.duracaoSegundos = duracaoSegundos;
        this.genero = genero;
    }

    void exibir() {
        System.out.println(titulo + " | " + artista + " | " + getDuracaoFormatada() + " | " + genero);
    }

    String getDuracaoFormatada() {
        int minutos = duracaoSegundos / 60;
        int segundos = duracaoSegundos % 60;
        return minutos + ":" + String.format("%02d", segundos);
    }
}
