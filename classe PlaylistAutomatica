package br.com.streaming.modelo;

import java.util.ArrayList;

public class PlaylistAutomatica extends Playlist {
    private String criterio;

    public PlaylistAutomatica(String nome, String criterio) {
        super(nome);
        this.criterio = criterio;
    }

    @Override
    public void reproduzir() {
        System.out.println("Playlist Automatica: " + nome);
        System.out.println("Criterio: " + criterio);
        super.reproduzir();
    }

    public void atualizar(ArrayList<Musica> todasMusicas) {
        musicas.clear();

        if (criterio.equals("top")) {
            int limite = 10;
            if (todasMusicas.size() < 10) {
                limite = todasMusicas.size();
            }
            for (int i = 0; i < limite; i++) {
                musicas.add(todasMusicas.get(i));
            }
        } else if (criterio.equals("recomendadas")) {
            int limite = 8;
            if (todasMusicas.size() < 8) {
                limite = todasMusicas.size();
            }
            for (int i = 0; i < limite; i++) {
                musicas.add(todasMusicas.get(i));
            }
        } else if (criterio.equals("recentes")) {
            int inicio = todasMusicas.size() - 12;
            if (inicio < 0) {
                inicio = 0;
            }
            for (int i = inicio; i < todasMusicas.size(); i++) {
                musicas.add(todasMusicas.get(i));
            }
        }

        System.out.println("Playlist " + nome + " atualizada com " + musicas.size() + " musicas!");
    }

    @Override
    public void exibirInfo() {
        System.out.print("[Automatica - " + criterio + "] ");
        super.exibirInfo();
    }
}
