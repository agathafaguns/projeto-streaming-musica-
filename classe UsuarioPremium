import java.util.ArrayList;

public class UsuarioPremium extends Usuario {
    String plano;
    ArrayList<Musica> baixadas;

    public UsuarioPremium(String nome, String email, String plano) {
        super(nome, email);
        this.plano = plano;
        this.baixadas = new ArrayList<>();
    }

    @Override
    public void reproduzirMusica(Musica musica) {
        System.out.println("ALTA QUALIDADE: " + musica.titulo);
        super.reproduzirMusica(musica);
    }

    public void baixarMusica(Musica musica) {
        for (Musica m : baixadas) {
            if (m.titulo.equals(musica.titulo)) {
                System.out.println("Musica ja baixada!");
                return;
            }
        }
        baixadas.add(musica);
        System.out.println("Download: " + musica.titulo);
    }

    public void verBaixadas() {
        System.out.println("\n--- MUSICAS BAIXADAS ---");
        if (baixadas.isEmpty()) {
            System.out.println("Nenhuma musica baixada.");
        } else {
            for (Musica m : baixadas) {
                m.exibir();
            }
        }
    }
}
