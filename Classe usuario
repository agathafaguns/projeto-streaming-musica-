import java.util.ArrayList;

public class Usuario {
    String nome;
    String email;
    ArrayList<Playlist> playlists;
    ArrayList<Musica> historico;
    int totalReproducoes;

    public Usuario(String nome, String email) {
        this.nome = nome;
        this.email = email;
        this.playlists = new ArrayList<>();
        this.historico = new ArrayList<>();
        this.totalReproducoes = 0;
    }

    public void reproduzirMusica(Musica musica) {
        System.out.println("Tocando: " + musica.titulo);
        historico.add(musica);
        totalReproducoes++;
    }

    public void verHistorico() {
        System.out.println("\n--- HISTORICO ---");
        if (historico.isEmpty()) {
            System.out.println("Nenhuma musica tocada.");
        } else {
            for (Musica m : historico) {
                m.exibir();
            }
        }
    }

    public void criarPlaylist(String nome) {
        PlaylistPersonalizada nova = new PlaylistPersonalizada(nome);
        playlists.add(nova);
        System.out.println("Playlist '" + nome + "' criada!");
    }

    public void listarPlaylists() {
        if (playlists.isEmpty()) {
            System.out.println("Nenhuma playlist.");
        } else {
            System.out.println("\n--- MINHAS PLAYLISTS ---");
            for (int i = 0; i < playlists.size(); i++) {
                Playlist p = playlists.get(i);
                if (p instanceof PlaylistAutomatica) {
                    System.out.println(i + ". " + p.nome + " [Automatica]");
                } else {
                    System.out.println(i + ". " + p.nome);
                }
            }
        }
    }
}
