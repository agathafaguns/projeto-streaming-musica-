package br.com.streaming.modelo;

public class UsuarioFree extends Usuario {
    private int musicasTocadasHoje;
    private int anunciosExibidos;

    public UsuarioFree(String nome, String email) {
        super(nome, email);
        this.musicasTocadasHoje = 0;
        this.anunciosExibidos = 0;
    }

    public int getAnunciosExibidos() {
        return anunciosExibidos;
    }

    @Override
    public void reproduzirMusica(Musica musica) {
        if (musicasTocadasHoje >= 30) {
            System.out.println("Limite diario de 30 musicas atingido!");
            System.out.println("Faca upgrade para Premium!");
            return;
        }

        musicasTocadasHoje++;

        if (musicasTocadasHoje % 3 == 0) {
            System.out.println("\nANUNCIO: Assine Premium e ouca sem pausas!");
            anunciosExibidos++;
        }

        super.reproduzirMusica(musica);
        System.out.println("Faltam " + (30 - musicasTocadasHoje) + " musicas hoje.");
    }

    @Override
    public void criarPlaylist(String nome) {
        if (playlists.size() >= 3) {
            System.out.println("Limite de 3 playlists atingido!");
            System.out.println("Premium tem playlists ilimitadas!");
            return;
        }
        super.criarPlaylist(nome);
    }

    @Override
    public String getTipoUsuario() {
        return "Free";
    }
}
